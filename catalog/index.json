    {
      "id": "dreaming",
      "version": "0.1.0",
      "category": "cognition",
      "description": "Generates novel hypotheses from accumulated bus history during quiet periods.",
      "personas": [
        "static",
        "dynamic"
      ],
      "provides": [
        "hypothesis"
      ],
      "requires": [],
      "setpoints": {
        "novelty_threshold": {
          "default": 0.7,
          "range": [
            0.0,
            1.0
          ],
          "description": "Min novelty to emit."
        },
        "max_history_lines": {
          "default": 50,
          "range": [
            10,
            500
          ],
          "description": "Bus lines to consider."
        }
      },
      "source": {
        "type": "git",
        "url": "https://github.com/avibrahms/system-zero.git",
        "ref": "v0.1.0",
        "path": "modules/dreaming"
      },
      "readme": "Dreaming reviews recent bus history during quiet periods and drafts structured hypotheses through the protocol's constrained LLM path. It is the repo's low-frequency ideation loop, gated by novelty and schema validation.\n"
    },
