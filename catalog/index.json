      "id": "metabolism",
      "version": "0.1.0",
      "category": "physiology",
      "description": "Rotates the bus log; archives older files.",
      "personas": [
        "static",
        "dynamic"
      ],
      "provides": [],
      "requires": [],
      "setpoints": {
        "rotate_after_days": {
          "default": 14,
          "range": [
            1,
            365
          ],
          "description": "Rotate when older than N days."
        },
        "rotate_after_mb": {
          "default": 50,
          "range": [
            1,
            1024
          ],
          "description": "Rotate when larger than N MB."
        }
      },
      "source": {
        "type": "git",
        "url": "https://github.com/avibrahms/system-zero.git",
        "ref": "v0.1.0",
        "path": "modules/metabolism"
      },
      "readme": "Metabolism keeps the append-only bus usable over time by rotating and archiving old event logs. It preserves the protocol's JSONL discipline while preventing long-running repositories from accumulating unbounded operational weight.\n"
    },
