{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://systemzero.dev/spec/v0.1.0/llm-responses/dreaming-hypothesis.schema.json",
  "title": "S0 Dreaming Hypothesis",
  "type": "object",
  "required": ["hypothesis", "novelty_score", "confidence", "rationale"],
  "additionalProperties": false,
  "properties": {
    "hypothesis": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    },
    "novelty_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000
    }
  }
}
